# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Real on-chain LP deposits.
# Keep ENABLE_SIMULATED_YIELD unset or false in production so deposits cannot
# fall back to local accounting.
ENABLE_SIMULATED_YIELD="false"
YIELD_ONCHAIN_NETWORK="mainnet-beta"
SOLANA_RPC_URL="https://api.mainnet-beta.solana.com"

# Configure the exact SOL/USDT pool accounts you want the app to use.
# Raydium/Orca require paired liquidity unless you add a pre-deposit swap route.
RAYDIUM_SOL_USDT_POOL=""
ORCA_SOL_USDT_POOL=""
METEORA_SOL_USDT_POOL=""
